---
import "../../styles/main.css";
import Layout from '../layouts/Layout.astro';
import Card from '../components/card.astro';
import ProductFilter from '../components/ProductFilter.astro';
import Sort from '../components/sort.astro';
const endpoint = 'https://zuieoildetgsrnwghaza.supabase.co/rest/v1/Beer?select=*';


const options ={
	headers:{
		apikey: "sb_publishable_fRKMouw3PcFSl16n3SjRxA_JOmMHW48",
	}
}

const data = await fetch(endpoint, options).then(response=>response.json());

//@ts-nocheck
---

<Layout>
  <h2 class="list-title">SPECIAL-ØL</h2>
	<p class="side-info">Vi har det bedste specialøl fra ind- og udland til markeds laveste priser. Øllet kan komme fra restpartier eller har etikettefejl, måske en lille bule. Du finder både øl med kort og lang best before-dato, så du nemt kan vælge det, der passer bedst til dig – uanset om det er til nu eller senere de skal drikkes.</p>
  <div class="controls-row">
    <ProductFilter />
    <Sort />
  </div>
  <section class="products-grid" id="PList">
		{data.map((product: any) => (<Card {product}/>))}
	</section>
</Layout>

<style>
  .list-title,
  .side-info,
  .products-grid {
    position: relative;
    z-index: 1;
  }

  .controls-row {
	position: relative;
	z-index: 100;
  }

  .list-title {
    margin: 24px 0 20px;
    text-align: center;
    font-family: "Anton", sans-serif;
    font-size: 4.2rem;
    line-height: 1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .side-info {
    max-width: 850px;
    margin: 0 auto 24px;
    padding: 0 16px;
    text-align: center;
    font-family: "Inter", sans-serif;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .controls-row {
    max-width: 1120px;
    margin: 0 auto 14px;
    padding: 0 8px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    max-width: 1120px;
    margin: 0 auto;
    align-items: stretch;
    padding: 0 8px 30px;
  }

  @media (max-width: 1000px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 680px;
    }

  }

  @media (max-width: 700px) {
    .list-title {
      font-size: 2.8rem;
      margin: 18px 0 8px;
    }

    .side-info {
      font-size: 0.95rem;
      margin-bottom: 18px;
    }

    .products-grid {
      gap: 18px;
      padding: 0 8px 24px;
    }

    .controls-row {
      margin-bottom: 12px;
    }
  }

  @media (max-width: 480px) {
    .side-info {
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .products-grid {
      gap: 14px;
      padding: 0 4px 18px;
    }

    .list-title {
      font-size: 3rem;
      margin: 22px 0 22px;
      text-align: center;
    }
  }
</style>
