---
import "../../styles/main.css";
import Layout from '../layouts/Layout.astro';
import Card from '../components/card.astro';
const endpoint = 'https://zuieoildetgsrnwghaza.supabase.co/rest/v1/Beer?select=*';


const options ={
	headers:{
		apikey: "sb_publishable_fRKMouw3PcFSl16n3SjRxA_JOmMHW48",
	}
}

const data = await fetch(endpoint, options).then(response=>response.json());

//@ts-nocheck
---

<Layout>
  <h2 class="list-title">SPECIAL-ØL</h2>
	<p class="side-info">Vi har det bedste specialøl fra ind- og udland til markeds laveste priser. Øllet kan komme fra restpartier eller har etikettefejl, måske en lille bule. Du finder både øl med kort og lang best before-dato, så du nemt kan vælge det, der passer bedst til dig – uanset om det er til nu eller senere de skal drikkes.</p>
	<section id="filter_buttons">
  <button data-type="ALLE">ALLE</button>
  <button data-type="IPA">IPA</button>
  <button data-type="LAGER">LAGER</button>
  <button data-type="PILSNER">PILSNER</button>
  <button data-type="ALE">ALE</button>
  <button data-type="ALKOHOLFRI">ALKOHOLFRI</button>
  <button data-type="SYRLIGE">SYRLIGE</button>
</section>
  <section class="products-grid">
		{data.map((product: any) => (<Card {product}/>))}
	</section>
</Layout>


<script>
  document
    .querySelectorAll("#filter_buttons button")
    .forEach((button) => {
      button.addEventListener("click", filter);
    });

  function filter(e) {
    const cards = document.querySelectorAll(".Pcard");
    const valgtType = e.target.dataset.type;

    cards.forEach((card) => {
      if (card.dataset.type === valgtType || valgtType === "ALLE") {
        card.classList.remove("hide");
      } else {
        card.classList.add("hide");
      }
    });
  }
</script>

<style>
  .list-title {
    margin: 24px 0 20px;
    text-align: center;
    font-family: "Anton", sans-serif;
    font-size: 4.2rem;
    line-height: 1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .side-info {
    max-width: 850px;
    margin: 0 auto 24px;
    padding: 0 16px;
    text-align: center;
    font-family: "Inter", sans-serif;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  #filter_buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    max-width: 1120px;
    margin: 0 auto 26px;
    padding: 0 8px;
  }

  #filter_buttons button {
    border: 2px solid var(--the-green);
    background: white;
    color: var(--the-green);
    font-family: var(--font);
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 8px;
    cursor: pointer;
    text-transform: uppercase;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    max-width: 1120px;
    margin: 0 auto;
    align-items: stretch;
    padding: 0 8px 30px;
  }

  @media (max-width: 1000px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 680px;
    }

  }

  @media (max-width: 640px) {
    .list-title {
      font-size: 2.8rem;
      margin: 18px 0 8px;
    }

    .side-info {
      font-size: 0.95rem;
      margin-bottom: 18px;
    }

    .products-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      padding: 0 8px 24px;
    }

    #filter_buttons {
      gap: 8px;
      margin-bottom: 20px;
    }

    #filter_buttons button {
      font-size: 0.9rem;
      padding: 5px 10px;
    }
  }

  @media (max-width: 480px) {
    .list-title {
      font-size: 2.2rem;
    }

    .side-info {
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .products-grid {
      gap: 14px;
      padding: 0 4px 18px;
    }

    .list-title {
      font-size: 3rem;
      margin: 22px 0 22px;
      text-align: center;
    }
  }
</style>
