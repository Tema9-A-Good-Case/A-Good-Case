---
import "../../../styles/main.css";
import Button from "../../components/button.astro";
import Marquee from "../../components/Marquee.astro";
import Layout from '../../layouts/Layout.astro';
import Checkout from "../../components/checkout.astro";

export async function getStaticPaths() {
  const endpoint = 'https://zuieoildetgsrnwghaza.supabase.co/rest/v1/Beer?select=*';

  const options = {
    headers: {
      apikey: "sb_publishable_fRKMouw3PcFSl16n3SjRxA_JOmMHW48",
    },
  };

  const response = await fetch(endpoint, options);
  const data = await response.json();

  return data.map((product: any) => {
    return {
      params: { id: product.Handle },
      props: { product },
    };
  });
}

const { product } = Astro.props as any;


const endpoint = 'https://zuieoildetgsrnwghaza.supabase.co/rest/v1/Beer?select=*';

const options = {
  headers: {
    apikey: "sb_publishable_fRKMouw3PcFSl16n3SjRxA_JOmMHW48",
  },
};

const res = await fetch(endpoint, options);
const allProducts = await res.json();

const lignendeProdukter = allProducts
  .filter((p: any) => p.Handle !== product.Handle)
  .slice(0, 3);


// @ts-nocheck
---
<Layout>
  
  <section class="grid_1-1-1">
    <div class="left_side">
<h2>{product.type}</h2>
<h2>{product.size}</h2>
<h2>{product.percent}</h2>
</div>

<img src={product.image} alt="productimage"/>


    <div class="right_side">
    <h1>{product.brand}</h1>
<h1>{product.name}</h1>
<div class="flex_stock">
<h2 class="stock">{product.stock}</h2>
<h2 class="best_before">BEST BEFORE: {product.date}</h2>
</div>

<div class="flex_price">
  <h2 class="new_price">{product.price_now} DKK</h2>

  {product.price_before && (
    <>
      <span class="divider">|</span>
      <h2 class="old_price">{product.price_before} DKK</h2>
    </>
  )}
</div>

<div class="flex_antal">
<h2>ANTAL:</h2>
<div class="options">
  <button class="option ">1 STK.</button>
  <button class="option active">6 STK.</button>
</div>
</div>

<div class="stepper">
  <button onclick="changeValue(-1)">-</button>
  <span id="value">1</span>
  <button onclick="changeValue(1)">+</button>
</div>

<div class="btn_class">
<button class="kurv_btn">LÆG I KURV</button>
</div>

<div class="accordion">
  <span>INFORMATION</span>
  <span id="arrow">⌄</span>
</div>

<div id="content" class="hidden">
  <p>{product.description}</p>
</div>
<div class="accordion">
  <span>UNTAPPD RATING</span>
  <span id="arrow">⌄</span>
</div>
</div>
</section>
	<Marquee />
<section class="product-section best-sellers">
  <h1>LIGNENDE PRODUKTER</h1>

<div class="products">
  {lignendeProdukter.map((item: any) => (
    <article class="product-card">
      <div class="product-image-wrap">
        {item.discount && (
          <span class="product-discount">
            SPAR {item.discount}
          </span>
        )}
        <img src={item.image} alt={item.name} />
      </div>

      <h3 class="product-brand">{item.brand}</h3>
      <p class="product-name">{item.name}</p>
      <p class="product-price">{item.price_now} DKK</p>
     <Button text="LÆG I KURV" />
    </article>
  ))}
</div>
<section class="service-icons">
  <div class="service-item">
    <h3>FRI FRAGT OVER 499,-</h3>
    <img src="/Imgs/fragt.webp" alt="Fri fragt" />
  </div>

  <div class="service-item levering">
    <h3>HURTIG LEVERING</h3>
    <img src="/Imgs/levering.webp" alt="Hurtig levering" />
  </div>

  <div class="service-item">
    <h3>PRISGARANTI</h3>
    <img src="/Imgs/pris.webp" alt="Prisgaranti" />
  </div>

  <div class="service-item">
    <h3>4.8 TRUSTPILOT</h3>
