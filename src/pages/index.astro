---
import Button from "../components/button.astro";
import Layout from '../layouts/Layout.astro';
const endpoint = "https://zuieoildetgsrnwghaza.supabase.co/rest/v1/Beer?select=*";

const options = {
  headers: {
    apikey: "sb_publishable_fRKMouw3PcFSl16n3SjRxA_JOmMHW48",
  },
};

let beers = [];

try {
  const res = await fetch(endpoint, options);
  beers = await res.json();
} catch (err) {
  console.error(err);
}

// split products
const nyheder = beers.slice(0, 4);
const mestSolgte = beers.slice(4, 8);
---

<Layout>
  <section class="hero">

    <div class="hero-left">
      <img src="/Imgs/Dagens-tilbud.webp" alt="Beer tilbud" class="hero-beers" />
      <img src="/Imgs/spar.webp" alt="Spar op til 60%" class="spar" />
      <div class="hero-btn">
        <Button text="SE TILBUD" />
      </div>
    </div>

    <div class="hero-center">
      <h1>
        <span>DAGENS</span>
        <span>TILBUD</span>
      </h1>
    </div>

    <div class="hero-right">
      <img src="/Imgs/circle-text.webp" alt="Markedets bedste ølpriser" />
    </div>

  </section>

    <section class="product-section">
      <h2 class="section-title">NYHEDER</h2>

      <div class="products">
        {nyheder.map((product: any) => (
          <article class="product-card">
            <img src={product.image} alt="productimage" />
            <h3 class="product-brand">{product.brand}</h3>
            <p class="product-name">{product.name}</p>
            <p class="product-price">{product.price_now} DKK</p>
            <Button text="LÆG I KURV" />
          </article>
        ))}
      </div>

      <div class="section-cta">
        <Button text="SE ALLE NYHEDER" href="/productlist" />
      </div>
    </section>

    <section class="product-section best-sellers">
      <h2 class="section-title">MEST SOLGTE</h2>

      <div class="products">
        {mestSolgte.map((product: any) => (
          <article class="product-card">
            <img src={product.image} alt="productimage" />
            <h3 class="product-brand">{product.brand}</h3>
            <p class="product-name">{product.name}</p>
            <p class="product-price">{product.price_now} DKK</p>
            <Button text="LÆG I KURV" />
          </article>
        ))}
      </div>

      <div class="section-cta">
        <Button text="SE MEST SOLGTE" href="/productlist" />
      </div>
    </section>
</Layout>

<style>

/* Hero Section */

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(220px, 420px) 1fr 260px;
    align-items: center;
    height: 350px;
    background: var(--the-beige);
    overflow: visible;
    padding: 0 0 0 32px;
  }

  .hero-left {
    position: relative;
    height: 100%;
    display: flex;
    align-items: flex-end;
	margin-left: 100px;
  }

  .hero-beers {
    height: 340px;
    width: auto;
    object-fit: contain;
  }

  .spar {
    position: absolute;
    top: 12px;
    left: -12px;
    width: 200px;
  }

  .hero-btn {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
  }

  .hero-center {
    display: flex;
    align-items: center;
    padding-left: 32px;
	margin-left: 100px;
  }

  .hero-center span:nth-child(1) {
	margin-left: 100px;
	display: block;
	margin-bottom: 20px;
  }

  .hero-center h1 {
    display: flex;
    flex-direction: column;
    margin: 0;
    font-family: "Anton", sans-serif;
    font-weight: 400;
    font-size: 10rem;
    line-height: 0.9;
    letter-spacing: 0.02em;
    color: var(--the-green);
  }

  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .hero-right img {
    width: 240px;
    height: 240px;
    object-fit: contain;
    transform: translateY(70%);
    position: relative;
    bottom: 0;
	margin-right: 100px;
  }

  /* Nyheder og Mest Solgte */
  .product-section {
    padding: 44px 32px 8px;
  }

  .best-sellers {
    margin-top: 30px;
  }

  .section-title {
    text-align: left;
    font-size: 5rem;
    font-family: 'Anton', sans-serif;
    line-height: 0.92;
    letter-spacing: 0.01em;
    margin: 0 150px 22px;
  }

  .products {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    max-width: 1120px;
    margin: 0 auto;
    align-items: stretch;
  }

  .product-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 470px;
  }

  .product-card img {
    width: 100%;
    height: 280px;
    object-fit: contain;
    margin-bottom: 6px;
  }

  .product-brand {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1;
    font-family: var(--font);
    text-transform: uppercase;
    min-height: 1.2rem;
  }

  .product-name {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.08;
    font-family: var(--font);
    text-transform: uppercase;
    max-width: 210px;
    min-height: 2.6rem;
    overflow: hidden;
  }

  .product-price {
    margin: 2px 0 8px;
    font-size: 1.05rem;
    font-family: var(--font);
    color: var(--the-green);
    font-weight: 700;
    text-transform: uppercase;
  }

  .section-cta {
    display: flex;
    justify-content: center;
    margin-top: 22px;
	font-family: var(--font);
  }

  .section-cta :global(.btn) {
    padding: 8px 20px;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  @media (max-width: 1000px) {
    .products {
      grid-template-columns: repeat(2, 1fr);
      max-width: 680px;
    }

    .product-section {
      padding: 34px 16px 8px;
    }
  }

  @media (max-width: 640px) {
    .section-title {
      font-size: 2.5rem;
      margin-bottom: 16px;
    }

    .products {
      gap: 18px;
    }

    .product-card img {
      width: min(100%, 160px);
      height: 220px;
    }

    .product-card {
      min-height: 410px;
    }

    .section-cta :global(.btn) {
      padding: 8px 16px;
      font-size: 1rem;
    }
  }
</style>
