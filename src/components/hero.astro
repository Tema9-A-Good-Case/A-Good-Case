---
import Button from "./button.astro";
---

<section class="hero">
  <div class="hero-left">
    <img src="/Imgs/Dagens-tilbud.webp" alt="Beer tilbud" class="hero-beers" />
    <img src="/Imgs/spar.webp" alt="Spar op til 60%" class="spar" />
    <div class="hero-btn">
      <Button text="SE TILBUD" />
    </div>
  </div>

  <div class="hero-center">
    <h1>
      <span>DAGENS</span>
      <span>TILBUD</span>
    </h1>
  </div>

  <div class="hero-right">
    <img src="/Imgs/circle-text.webp" alt="Markedets bedste ølpriser" />
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(220px, 420px) 1fr 260px;
    align-items: center;
    height: 350px;
    background: var(--the-beige);
    padding: 0 0 0 32px;
  }

  .hero-left {
    position: relative;
    height: 100%;
    display: flex;
    align-items: flex-end;
    margin-left: 100px;
  }

  .hero-beers {
    height: 340px;
    width: auto;
    object-fit: contain;
  }

  .spar {
    position: absolute;
    top: 12px;
    left: -12px;
    width: 200px;
  }

  .hero-btn {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    
  }


    .hero-btn :global(.btn) {
      font-size: 1.3rem;
      padding: 12px 28px;
    }
  

  .hero-center {
    display: flex;
    align-items: center;
    padding-left: 32px;
    margin-left: 100px;
  }

  .hero-center span:nth-child(1) {
    margin-left: 100px;
    display: block;
    margin-bottom: 20px;
  }

  .hero-center h1 {
    display: flex;
    flex-direction: column;
    margin: 0;
    font-family: "Anton", sans-serif;
    font-weight: 400;
    font-size: 10rem;
    line-height: 0.9;
    letter-spacing: 0.02em;
    color: var(--the-green);
  }

  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .hero-right img {
    width: 300px;
    height: 300px;
    object-fit: contain;
    transform: translateY(60%);
    position: relative;
    margin-right: 100px;
  }

  @media (max-width: 640px) {
    .hero {
      display: flex;
      flex-direction: column;
      height: auto;
      padding: 0 16px;
    }

    .hero-center {
      order: -1;
      padding-left: 0;
      margin-left: 0;
      text-align: center;
      padding: 24px 0 16px;
    }

    .hero-center span {
        font-size: 4rem;
    }

    .hero-center span:nth-child(1) {
      margin-left: 0;
      margin-bottom: 12px;
    }

    .hero-center h1 {
      font-size: 3rem;
    }

    .hero-left {
      margin-left: 0;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 280px;
    }

    .hero-beers {
      height: 220px;
    }

    .spar {
      width: 120px;
      top: 8px;
      left: -8px;
    }

    .hero-btn {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      white-space: nowrap;
    }


    .hero-right {
      display: none;
    }
  }

  /* Very small screens */
  @media (max-width: 480px) {
    .hero {
      padding: 0;
    }

    .hero-beers {
      height: 300px;
    }

    .spar {
      width: 160px;
      top: 8px;
      left: -8px;
    }

    .hero-center h1 {
      font-size: 2.5rem;
    }

    .hero-center {
      padding: 16px 0;
    }

    .hero-btn :global(.btn) {
      font-size: 1.25rem;
      padding: 12px 24px;
      transform: translateY(-50%);
    }
  }
</style>
