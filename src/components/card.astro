---
import Button from "./button.astro";

const { product } = Astro.props;
---

<a href={`/details/${product.Handle}`} class="Pcard" data-type={product.Type} data-price={product.price_now}>
    <article class="product-card">
        <div class="product-image-wrap">
            {product.discount && (
                <span class="product-discount">SPAR {product.discount}</span>
            )}
            <img src={product.image} alt="productimage" />
        </div>

        <h3 class="product-brand">{product.brand}</h3>
        <p class="product-name">{product.name}</p>
        <p class="product-price">{product.price_now} DKK</p>

        <div class="card-button">
            <Button text="LÆG I KURV" />
        </div>
    </article>
</a>

<style>
    .Pcard {
        text-decoration: none;
        color: inherit;
        display: block;
        height: 100%;
    }

    .product-card {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 450px;
        height: 100%;
        border: 1px solid #e6e6e6;
        border-radius: 10px;
        padding: 10px;
        transition: transform 0.2s ease, box-shadow 0.2s ease,
            border-color 0.2s ease;
    }

    .Pcard:hover .product-card {
        transform: translateY(-3px);
        border-color: #d0d0d0;
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.08);
    }

    .product-image-wrap {
        position: relative;
        width: 100%;
    }

    .product-card img {
        width: 100%;
        height: 280px;
        object-fit: contain;
        margin-bottom: 6px;
    }

    .product-discount {
        position: absolute;
        top: 8px;
        left: 8px;
        z-index: 1;
        padding: 4px 10px;
        border-radius: 8px;
        background: var(--the-green);
        color: white;
        font-size: 0.85rem;
        font-family: var(--font);
        font-weight: 700;
        text-transform: uppercase;
        line-height: 1;
    }

    .product-brand {
        margin: 0;
        font-size: 1.2rem;
        line-height: 1;
        font-family: var(--font);
        text-transform: uppercase;
        min-height: 1.2rem;
    }

    .product-name {
        margin: 0;
        font-size: 0.9rem;
        line-height: 1.08;
        font-family: var(--font);
        text-transform: uppercase;
        max-width: 210px;
        overflow: hidden;
    }

    .product-price {
        margin: 2px 0 8px;
        font-size: 1.05rem;
        font-family: var(--font);
        color: var(--the-green);
        font-weight: 700;
        text-transform: uppercase;
    }

    .hide {
        display: none;
    }

    @media (max-width: 700px) {
        .product-card img {
            width: min(100%, 160px);
            height: 220px;
        }

        .product-card {
            min-height: 410px;
        }
    }

    @media (max-width: 480px) {
        .product-card {
            min-height: 360px;
        }

        .product-card img {
            height: 180px;
            width: 100%;
        }

        .product-brand {
            font-size: 1rem;
        }

        .product-name {
            font-size: 0.8rem;
            max-width: 100%;
        }

        .product-price {
            font-size: 0.95rem;
        }
    }
</style>