---
const {product} = Astro.props;
---

<a href={`/details/${product.Handle}`}>
     <article>      
            <img src={product.image} alt="productimage"/>
            <h3>{product.brand}</h3>
			<h3>{product.name}</h3>
			<p>kr. {product.price_now},-</p>
    </article> 
</a>

    <style>
        article {
            border: 1px solid black;
            padding: 10px;
            margin: 10px;
        }

        a {
            text-decoration: none;
            color: black;
        }


        img {
            width: 100%;
        }

    
    </style>