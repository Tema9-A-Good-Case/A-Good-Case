<style>
  .site-footer {
    background: var(--the-background);
    padding: 60px 20px;
    border-top: 5px solid var(--the-beige);
  }

  .footer-inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    padding-inline: 20px;
  }

  .footer-col {
    text-align: center;
  }

  .footer-col h2 {
    font-family: "Anton", sans-serif;
    font-weight: 400;
    letter-spacing: 0.02em;
    margin-bottom: 40px;
  }

  .footer-col p,
  .footer-col a {
    font-family: var(--font);
    display: block;
    margin-bottom: 10px;
    text-decoration: none;
    color: black;
  }

  .footer-col:first-child p:nth-of-type(3) {
    margin-top: 30px;
  }

  .center {
    text-align: center;
  }

  .footer-logo {
    width: 300px;
    margin: 60px auto 0;
  }

  .footer-bottom {
    margin-top: 50px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: end;
    gap: 16px;
  }

  .socials {
    display: flex;
    align-items: center;
    justify-self: start;
    gap: 15px;
    padding-left: 150px;
  }

  .socials img {
    width: 24px;
    height: 24px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .age-badge {
    width: 200px;
    justify-self: center;
  }

  .trustpilot {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    justify-self: end;
    gap: 10px;
    padding-right: 150px;
    font-family: var(--font);
    font-size: 14px;
  }

  .trustpilot img {
    width: 80px;
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: center;
    }

    .footer-logo {
      width: 250px;
    }

    .footer-bottom {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: 20px;
    }

    .socials,
    .trustpilot,
    .age-badge {
      justify-self: center;
    }

    .socials,
    .trustpilot {
      padding-left: 0;
      padding-right: 0;
    }
  }
</style>