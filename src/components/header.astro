---
const cartCount = 3;
---

<header class="site-header">
  <div class="header-inner">
    <button class="icon-button menu-button" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <a href="/" class="brand" aria-label="A Good Case homepage">
      <img src="Imgs/Logo.webp" alt="A Good Case" class="brand-logo" />
       </a>

    <!-- Right: Icons -->
    <div class="header-actions">
      <a href="/search" class="icon-button">
        <img src="Imgs/search.webp" alt="Search" />
      </a>

      <a href="/account" class="icon-button">
        <img src="Imgs/profile.webp" alt="Account" />
      </a>

      <a href="/cart" class="icon-button cart-button">
        <img src="Imgs/cart.webp" alt="Cart" />

        {cartCount > 0 && (
          <span class="cart-badge">{cartCount}</span>
        )}
      </a>
    </div>

  </div>
</header>

<style>
  .site-header {
    background: var(--the-background);
    border-bottom: 5px solid var(--the-beige);
  }

  .header-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 20px 28px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  .menu-button {
    justify-self: start;
    width: 44px;
    height: 44px;
    padding: 8px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .menu-button span {
    display: block;
    width: 24px;
    height: 3px;
    background: var(--the-black);
    border-radius: 999px;
  }

  .icon-button {
    position: relative;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-button img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--the-black);
  }

  .brand-logo {
    width: 250px;
  }

  .brand-tagline {
    display: flex;
    gap: 16px;
    font-weight: 800;
    font-size: 1.5rem;
  }

  .header-actions {
    display: flex;
    width: 100%;
    justify-content: flex-end;
    gap: 10px;
  }

  .cart-button {
    position: relative;
  }

  .cart-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--the-green);
    color: white;
    font-size: 0.8rem;
    font-family: var(--font);
    font-weight: var(--font-weight-medium);
    padding: 4px 8px;
    border-radius: 999px;
  }

  @media (max-width: 768px) {
    .header-inner {
      grid-template-columns: auto 1fr auto;
      gap: 8px;
      padding: 14px 16px;
    }

    .brand {
      justify-self: center;
    }

    .brand-logo {
      width: 140px;
    }

    .icon-button {
      width: 44px;
      height: 44px;
    }

    .header-actions {
      gap: 4px;
    }
  }
</style>