---
import Menu from "./Menu.astro";
const cartCount = 3;
---

<header class="site-header">
  <div class="header-inner">
  <Menu />

    <a href="/" class="brand" aria-label="A Good Case homepage">
      <img src="/Imgs/Logo.webp" alt="A Good Case" class="brand-logo" />
       </a>

    <!-- Right: Icons -->
    <div class="header-actions">
      <a href="/search" class="icon-button">
        <img src="/Imgs/search.webp" alt="Search" />
      </a>

      <a href="/account" class="icon-button">
        <img src="/Imgs/profile.webp" alt="Account" />
      </a>

      <a href="/cart" class="icon-button cart-button">
        <img src="/Imgs/cart.webp" alt="Cart" />

        {cartCount > 0 && (
          <span class="cart-badge">{cartCount}</span>
        )}
      </a>
    </div>

  </div>
</header>

<style>
  .site-header {
    background: var(--the-background);
    border-bottom: 5px solid var(--the-beige);
  }

  .header-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 20px 28px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  .icon-button {
    position: relative;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-button img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--the-black);
  }

  .brand-logo {
    width: 250px;
  }

  .header-actions {
    display: flex;
    width: 100%;
    justify-content: flex-end;
    gap: 10px;
  }

  .cart-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--the-green);
    color: white;
    font-size: 0.8rem;
    font-family: var(--font);
    font-weight: var(--font-weight-medium);
    padding: 4px 8px;
    border-radius: 999px;
  }

  @media (max-width: 768px) {
    .header-inner {
      grid-template-columns: auto 1fr auto;
      gap: 8px;
      padding: 14px 16px;
    }

    .brand {
      justify-self: center;
    }

    .brand-logo {
      width: 168px;
    }

    .icon-button {
      width: 36px;
      height: 36px;
    }

    .icon-button img {
      width: 20px;
      height: 20px;
    }

    .header-actions {
      gap: 2px;
    }

    .cart-badge {
      top: 1px;
      right: -2px;
      font-size: 0.62rem;
      padding: 2px 5px;
      min-width: 16px;
      text-align: center;
      line-height: 1;
    }
  }

  @media (max-width: 480px) {
    .header-inner {
      padding: 12px 10px;
      gap: 6px;
    }

    .brand-logo {
      width: 182px;
    }

    .icon-button {
      width: 32px;
      height: 32px;
    }

    .icon-button img {
      width: 22px;
      height: 22px;
    }

    .header-actions {
      gap: 1px;
    }

    .cart-badge {
      top: -5px;
      right: -3px;
      font-size: 0.7rem;
      padding: 4px 6px;
      min-width: 14px;
    }
  }
</style>