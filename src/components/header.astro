---
const cartCount = 3;
import "../styles/main.css";
---

<header class="site-header">
  <div class="header-inner">
    <button class="icon-button menu-button" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <a href="/" class="brand" aria-label="A Good Case homepage">
      <img src="Imgs/Logo.webp" alt="A Good Case" class="brand-logo" />
       </a>

    <!-- Right: Icons -->
    <div class="header-actions">
      <a href="/search" class="icon-button">
        <img src="Imgs/search.webp" alt="Search" />
      </a>

      <a href="/account" class="icon-button">
        <img src="Imgs/profile.webp" alt="Account" />
      </a>

      <a href="/cart" class="icon-button cart-button">
        <img src="Imgs/cart.webp" alt="Cart" />

        {cartCount > 0 && (
          <span class="cart-badge">{cartCount}</span>
        )}
      </a>
    </div>

  </div>
</header>

<style>
  .site-header {
    background: var(--the-background);
    border-bottom: 1px solid var(--the-beige);
  }

  .header-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 20px 28px;
    display: grid;
    grid-template-columns: 80px 1fr 180px;
    align-items: center;
  }

  .icon-button {
    position: relative;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-button img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--the-black);
  }

  .brand-logo {
    width: 120px;
  }

  .brand-tagline {
    display: flex;
    gap: 16px;
    font-weight: 800;
    font-size: 1.5rem;
  }

  .header-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }

  .cart-button {
    position: relative;
  }

  .cart-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--the-green);
    color: white;
    font-size: 0.8rem;
    padding: 4px 8px;
    border-radius: 999px;
  }
</style>