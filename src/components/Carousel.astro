---
const logos = [
  { src: "/Imgs/alefarm.webp", alt: "Alefarm Brewing" },
  { src: "/Imgs/brutal.webp", alt: "Brutal Brewing" },
  { src: "/Imgs/dry.webp", alt: "Dry & Bitter" },
  { src: "/Imgs/to.webp", alt: "To Øl" },
  { src: "/Imgs/gamma.webp", alt: "Gamma Brewing Co." },
  { src: "/Imgs/amager.webp", alt: "Amager Bryghus" },
  { src: "/Imgs/founders.webp", alt: "Founders Brewing" },
  { src: "/Imgs/northern.webp", alt: "Northern Monk" },
  { src: "/Imgs/crew.webp", alt: "Crew Republic" },
];

const trackLogos = [...logos, ...logos];
---

<section class="brewery-carousel">
  <h2>UDPLUK AF BRYGHUSE</h2>

  <div class="carousel-window">
    <div class="carousel-track">
      {trackLogos.map((logo) => (
        <div class="logo-item">
          <img src={logo.src} alt={logo.alt} />
        </div>
      ))}
    </div>
  </div>

  <div class="carousel-dots">
    <!--one dot per original logo (not per duplicated logo).
      i starts at 0, so the first dot gets "is-active" on first load.
    -->
    {logos.map((_, i) => (
      <button
        class:list={["carousel-dot", i === 0 && "is-active"]} 
        type="button"
      />
    ))}
  </div>
</section>

<script>
  //@ts-nocheck


  const track = document.querySelector(".carousel-track");
  const dots = document.querySelectorAll(".carousel-dot");
  let index = 0;
  // Total real steps (same as number of dots).
  const total = dots.length;

  // Updates the carousel position and active dot.
  function update(animate = true) {
    track.style.transition = animate ? "transform 0.2s ease" : "none"; 

    // Each step moves 20% because desktop view shows 5 logos (100/5 = 20).
    // feks. index 1 = -20%, index 2 = -40%
    track.style.transform = `translateX(-${index * 20}%)`;

    // Highlights the correct dot.
    // so after last dot it goes back to first.
    dots.forEach((dot, i) =>
      dot.classList.toggle("is-active", i === index % total)
    );
  }

  dots.forEach((dot, i) => {
    dot.onclick = () => {
      index = i;
      update();
    };
  });

  setInterval(() => {
    index++;
    update();
  }, 2000);

  // Infinite-loop trick
  // When we pass the real end, we subtract total and jump back instantly
  track.addEventListener("transitionend", () => {
    if (index >= total) {
      index -= total;
      update(false);
    }
  });

  // Initial render without animation to avoid glitcch
  update(false);
</script>

<style>
  .brewery-carousel {
    background: var(--the-background);
    padding: 40px 20px 30px;
    text-align: center;
  }

  .brewery-carousel h2 {
    margin: 0 0 60px;
    color: #000;
    font-family: "Anton", sans-serif;
    font-size: 4.5rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .carousel-window {
    overflow: hidden;
    max-width: 1200px;
    margin: 0 auto;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.2s ease;
  }


  /* Desktop: 5 logos */
  .logo-item {
    flex: 0 0 20%;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 120px;
  }

  .logo-item img {
    max-width: 140px;
    max-height: 90px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 26px;
  }

  .carousel-dot {
    width: 12px;
    height: 12px;
    border: 0;
    border-radius: 999px;
    background: #d3d3d3;
    cursor: pointer;
    padding: 0;
  }

  .carousel-dot.is-active {
    background: #000;
  }

  @media (max-width: 1000px) {
    .logo-item img {
      max-width: 110px;
      max-height: 70px;
    }

    .brewery-carousel h2 {
      font-size: 3rem;
      margin: 0 0 48px;
    }
  }

  @media (max-width: 700px) {
     /* mobile: 3 logos */
        .logo-item {
      flex: 0 0 33.333%;
    }
    
    .brewery-carousel {
      padding: 32px 16px 24px;
    }

    .brewery-carousel h2 {
      font-size: 2rem;
      margin: 0 0 36px;
    }

    .carousel-dots {
      gap: 8px;
      margin-top: 20px;
    }

    .carousel-dot {
      width: 10px;
      height: 10px;
    }

    .logo-item {
      min-height: 100px;
    }

    .logo-item img {
      max-width: 90px;
      max-height: 60px;
    }
  }

  @media (max-width: 480px) {
    .brewery-carousel {
      padding: 24px 12px 20px;
    }

    .brewery-carousel h2 {
      font-size: 2.2rem;
      margin: 0 0 28px;
    }

    .carousel-dots {
      gap: 6px;
      margin-top: 16px;
    }

    .carousel-dot {
      width: 8px;
      height: 8px;
    }

    .logo-item {
      min-height: 80px;
    }

    .logo-item img {
      max-width: 70px;
      max-height: 50px;
    }
  }
</style>
